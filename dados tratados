import pandas as pd
def limpezadata(df):
    for linnha in df:
        df[0]=df.astype(str)
    return(df)

dfpatriliquido=pd.read_excel('dadosnag.xlsx.',sheet_name='patriliquido')
dfreceber=pd.read_excel('dadosnag.xlsx.',sheet_name='valoresareceber')
dfcaixa=pd.read_excel('dadosnag.xlsx.',sheet_name='caixa')
dfpagar=pd.read_excel('dadosnag.xlsx.',sheet_name='valorespagar')

dfliquido=dfpatriliquido['mesano']
dfreceber=dfreceber['mesano']
dfcaixa=dfcaixa['mesano']
dfvalorpagar=dfpagar['mesano']

limpezadata(dfliquido)
limpezadata(dfreceber)
limpezadata(dfcaixa)
limpezadata(dfvalorpagar)
#transforma arquivo em CSV
dfpatriliquido.to_csv('PATRILIQUIDO',sep=',',encoding='UTF-8')

