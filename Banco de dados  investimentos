Create database fundosdeinvestimento;
use fundosdeinvestimento;

CREATE TABLE imobi (
idimobi int primary key ,
codigo varchar(50000),
tipo varchar(50000),
valor decimal(10,7),
registro date,
ex date,
pagamento date
);

CREATE TABLE valores (
idacoes	INT PRIMARY KEY,
codigo	TEXT(50000),
nome	TEXT(50000),
negocios decimal(10,5),
ultima	decimal(10,5),
variacao decimal(10,5)																			
);

CREATE TABLE cripto  (
criptoativo	varchar(50000),
mesano	date,
numoperacao	decimal(10,3),
numtotaloperacao decimal(10,3),
vmporoperacao decimal(10,3)																				
);

alter table valores
add constraint fk_valores_imobi
foreign key (idacoes) references imobi(idimobi);

use fundosdeinvestimento;
Select idimobi 
from imobi 
where idimobi >550;

Select COUNT(*) AS total_cripto, 
sum(numoperacao) AS totaloperacao, 
AVG(numtotaloperacao) AS mediatotal 
from cripto;

select nome,
sum(negocios) as sumnegocios,
sum(ultima)  as sumultima,
sum(variacao) as sumvariacao,
AVG(negocios) as medianegocio,
AVG(ultima) as mediaultima,
Avg(variacao) as mediavariacao
from valores
group by nome;

select codigo,
AVG(valor) as mediarendimento
from imobi
group by codigo;

select i.idimobi, a.idacoes as id_de_valor
from valores as a
INNER JOIN imobi as i ON a.idacoes = i.idimobi

import mysql.connector
def bancodedados(query):
    try:
        conexao = mysql.connector.connect(
            host="localhost",
            user="root",
            password="",
            database="fundosdeinvestimento"
        )
        cursor = conexao.cursor()
        cursor.execute(query)
        resultados = cursor.fetchall()
        return resultados
    except mysql.connector.Error as erro:
        print(f"Erro ao conectar ao MySQL: {erro}")
        return None
    finally:
        if 'conexao' in locals() and conexao.is_connected():
            cursor.close()
            conexao.close()

