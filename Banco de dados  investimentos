Create database fundosdeinvestimento;
use fundosdeinvestimento;

create table imobi(
idimobi int primary key not null,
codigo varchar(800),
tipo varchar(10000),
valor decimal(10,6),
registro date,
ex date,
pagamento date
);

create table valores(
idacoes int primary key not null,
codigo varchar(800),
nome varchar(1000),
negocios decimal(10,2) ,
ultima decimal(10,2),
variacao decimal(10,4)
);

create table cripto(
criptoativo varchar(1000),
mesano date,
numoperacao decimal(10,3),
numtotaloperacao decimal(10,3),
vmporoperacao decimal(10,2)
);

alter table valores
add constraint fk_valores_imobi
foreign key (idacoes) references imobi(idimobi);

Select idimobi valor 
from imobi 
where idimobi ='4' and valor >'1,1';

Select 
COUNT(*) AS total_pedidos,
SUM(numoperacao) AS totaloperacao,
AVG(numtotaloperacao) AS mediatotal 
from cripto;

select codigo,
AVG(valor) as mediarendimento
from imobi
group by codigo
having AVG(valor)>0;

select nome,
sum(negocios) as sumnegocios,
sum(ultima)  as sumultima,
sum(variacao) as sumvariacao,
AVG(negocios) as medianegocio,
AVG(ultima) as mediaultima,
Avg(variacao) as mediavariacao
from valores
group by nome;

select i.idimobi, a.idacoes as id_de_valor
from valores as a
INNER JOIN imobi as i ON a.idacoes = i.idimobi
